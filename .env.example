# ──────────────────────────────────────────────────────────────────────────
# Pellametric — required environment for apps/web (and apps/collector dev).
# Real .env is gitignored; copy this template and fill in.
# ──────────────────────────────────────────────────────────────────────────

# ── Database ──
DATABASE_URL=postgresql://user:pass@host:5432/db

# ── better-auth (GitHub OAuth) ──
BETTER_AUTH_SECRET=openssl_rand_hex_32_output
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitLab OAuth (optional — multi-provider)
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# ── GitHub App (PR webhooks, lineage hydration) ──
# Create at https://github.com/settings/apps and install on your org.
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_SLUG=
GITHUB_APP_WEBHOOK_SECRET=
# PEM-encoded private key. Escape newlines with \n or use a multi-line value.
GITHUB_APP_PRIVATE_KEY=

# Optional: GitHub PAT for scripts that don't have App context.
GITHUB_TOKEN=

# ── Prompt encryption (REQUIRED to ingest prompts/responses) ──
# 32 random bytes, base64-encoded: `openssl rand -base64 32`
PROMPT_MASTER_KEY=

# ── Insights revamp (Phase 1+) ──
# Internal-API gate (lineage run/sweep, backfill). Quarterly rotation supported.
INTERNAL_API_SECRET=
INTERNAL_API_SECRET_PREVIOUS=

# Feature flag — flip to '1' to expose the revamped insights UI.
PELLAMETRIC_INSIGHTS_REVAMP_UI=0

# Retention sweep batch size for prompt/response GC. Default 1000.
RETENTION_DELETE_LIMIT=1000

# Optional Slack-incident webhook for /api/health/lineage 503 alerts.
LINEAGE_ALERT_WEBHOOK=

# ── Self-hosted GitLab support (optional) ──
# Comma-separated list. gitlab.com is always recognized.
PELLA_GITLAB_HOSTS=

# ── Marketing site ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Collector (apps/collector) — for the bundled legacy /setup/collector route ──
# Compiled into apps/web/public/collector.mjs at build time.
PELLA_COLLECTOR_DEFAULT_URL=http://localhost:3000

# ── Local-only dev affordances ──
# When set to '1', DO NOT deploy to prod. Enables /api/dev/mint-session
# (gitignored route) for end-to-end testing without GitHub OAuth.
DEV_AUTH_BYPASS=0
